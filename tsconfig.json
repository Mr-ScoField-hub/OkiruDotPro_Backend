{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",

    "outDir": "dist",
    "rootDir": ".",

    "strict": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,

    "types": ["node"]
  },

  "include": [
    "**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}